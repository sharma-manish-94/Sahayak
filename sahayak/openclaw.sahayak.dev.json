{
  "$comment": "Sahayak DEV config — uses Sarvam (free sovereign LLM) or local Ollama. Switch to production config for Sonnet.",

  "models": {
    "providers": {
      "sarvam": {
        "baseUrl": "https://api.sarvam.ai/v1",
        "api": "openai-completions",
        "apiKey": "${SARVAM_API_KEY}",
        "models": [
          {
            "id": "sarvam-m",
            "name": "Sarvam M (sovereign, free)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      },
      "ollama": {
        "baseUrl": "http://localhost:11434/v1",
        "api": "openai-completions",
        "apiKey": "ollama-local",
        "models": [
          {
            "id": "qwen2.5:14b",
            "name": "Qwen 2.5 14B (local)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "llama3.1:8b",
            "name": "Llama 3.1 8B (local)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "gemma3:12b",
            "name": "Gemma 3 12B (local)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "list": [
      {
        "id": "sahayak",
        "default": true,
        "name": "Sahayak",
        "agentDir": "./sahayak/agent",
        "model": {
          "primary": "ollama/qwen2.5:14b",
          "fallbacks": ["ollama/llama3.1:8b", "ollama/gemma3:12b"]
        },
        "skills": ["sahayak-lang", "sahayak-gov"]
      }
    ]
  },

  "bindings": [
    {
      "agentId": "sahayak",
      "match": {
        "channel": "whatsapp"
      }
    }
  ],

  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "open",
      "groupPolicy": "disabled"
    }
  },

  "messages": {
    "tts": {
      "auto": "inbound",
      "provider": "edge",
      "edge": {
        "enabled": true,
        "voice": "hi-IN-SwaraNeural",
        "lang": "hi-IN"
      }
    }
  },

  "gateway": {
    "bind": "loopback"
  },

  "skills": {
    "allowBundled": ["sahayak-lang", "sahayak-gov"],
    "load": {
      "extraDirs": ["./skills"]
    }
  },

  "plugins": {
    "allow": ["whatsapp", "ollama"]
  },

  "tools": {
    "deny": ["bash", "computer", "file_write", "file_edit"]
  },

  "mcp": {
    "servers": {
      "bhashini-lang": {
        "command": "python",
        "args": ["-m", "bhashini_lang.server"],
        "cwd": "./sahayak/bhashini-lang",
        "env": {
          "LANG_PROVIDER": "${LANG_PROVIDER:-auto}",
          "SARVAM_API_KEY": "${SARVAM_API_KEY}",
          "BHASHINI_ULCA_USER_ID": "${BHASHINI_ULCA_USER_ID}",
          "BHASHINI_ULCA_API_KEY": "${BHASHINI_ULCA_API_KEY}"
        }
      },
      "govdata-india": {
        "command": "python",
        "args": ["-m", "govdata_india.server"],
        "cwd": "./sahayak/govdata-india",
        "env": {
          "DATA_GOV_IN_API_KEY": "${DATA_GOV_IN_API_KEY}"
        }
      }
    }
  }
}
