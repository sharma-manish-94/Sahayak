{
  "$comment": "Sahayak SOVEREIGN config — 100% Indian stack. Sarvam LLM + Sarvam language services + data.gov.in. Zero dependency on US cloud APIs.",

  "models": {
    "providers": {
      "sarvam": {
        "baseUrl": "https://api.sarvam.ai/v1",
        "api": "openai-completions",
        "apiKey": "${SARVAM_API_KEY}",
        "models": [
          {
            "id": "sarvam-m",
            "name": "Sarvam M (sovereign)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "list": [
      {
        "id": "sahayak",
        "default": true,
        "name": "Sahayak",
        "agentDir": "./sahayak/agent",
        "model": {
          "primary": "sarvam/sarvam-m"
        },
        "skills": ["sahayak-lang", "sahayak-gov"]
      }
    ]
  },

  "bindings": [
    {
      "agentId": "sahayak",
      "match": {
        "channel": "whatsapp"
      }
    }
  ],

  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "open",
      "groupPolicy": "disabled"
    }
  },

  "messages": {
    "tts": {
      "auto": "inbound",
      "provider": "edge",
      "edge": {
        "enabled": true,
        "voice": "hi-IN-SwaraNeural",
        "lang": "hi-IN"
      }
    }
  },

  "gateway": {
    "bind": "loopback"
  },

  "skills": {
    "allowBundled": ["sahayak-lang", "sahayak-gov"],
    "load": {
      "extraDirs": ["./skills"]
    }
  },

  "plugins": {
    "allow": ["whatsapp"]
  },

  "tools": {
    "deny": ["bash", "computer", "file_write", "file_edit"]
  },

  "mcp": {
    "servers": {
      "bhashini-lang": {
        "command": "python",
        "args": ["-m", "bhashini_lang.server"],
        "cwd": "./sahayak/bhashini-lang",
        "env": {
          "LANG_PROVIDER": "sarvam",
          "SARVAM_API_KEY": "${SARVAM_API_KEY}"
        }
      },
      "govdata-india": {
        "command": "python",
        "args": ["-m", "govdata_india.server"],
        "cwd": "./sahayak/govdata-india",
        "env": {
          "DATA_GOV_IN_API_KEY": "${DATA_GOV_IN_API_KEY}"
        }
      }
    }
  }
}
