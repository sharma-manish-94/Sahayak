# Sahayak Environment Variables
#
# Setup:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below (all keys are free tier)
#   3. Never commit .env to git — it's already in .gitignore
#
# How it loads:
#   - OpenClaw gateway auto-loads .env from the working directory
#   - Docker Compose reads .env via env_file directive
#   - Python code reads via os.environ.get("VAR_NAME")
#   - No python-dotenv needed — the gateway handles it

# =============================================================================
# REQUIRED — Government Data APIs
# =============================================================================

# data.gov.in API key (free)
# Register at: https://data.gov.in/ → Profile → API Key
DATA_GOV_IN_API_KEY=

# =============================================================================
# REQUIRED — Language Services (choose one provider)
# =============================================================================

# Option A: Bhashini ULCA (default, free PoC tier)
# Register at: https://bhashini.gov.in/ulca → Sign Up → Get credentials
BHASHINI_ULCA_USER_ID=
BHASHINI_ULCA_API_KEY=

# Option B: Sarvam AI (sovereign Indian alternative)
# Register at: https://www.sarvam.ai/ → Get API Key
SARVAM_API_KEY=

# Language provider selector: "bhashini", "sarvam", or "auto" (default)
# "auto" uses Sarvam if SARVAM_API_KEY is set, otherwise Bhashini
# LANG_PROVIDER=auto

# =============================================================================
# REQUIRED — LLM Provider (choose one)
# =============================================================================

# Option A: Anthropic Claude Sonnet (production, recommended)
# Register at: https://console.anthropic.com/ → API Keys
#ANTHROPIC_API_KEY=

# Option B: Local Ollama (free, no API key needed)
# Install Ollama: https://ollama.com/
# Pull a model: ollama pull qwen2.5:14b
# Start Ollama: ollama serve
# Use config: openclaw.sahayak.dev.json

# =============================================================================
# OPTIONAL — Fallback Services
# =============================================================================

# OpenAI API key — used for Whisper ASR fallback when Bhashini is down
# Register at: https://platform.openai.com/ → API Keys
# OPENAI_API_KEY=

# =============================================================================
# OPTIONAL — Gateway Security
# =============================================================================

# Gateway auth token — recommended if binding beyond localhost
# Generate with: openssl rand -hex 32
# OPENCLAW_GATEWAY_TOKEN=
